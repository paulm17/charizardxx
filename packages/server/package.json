{
  "name": "@charizardxx/server",
  "version": "0.0.1-alpha.3",
  "description": "Charizardxx UI server",
  "keywords": [
    "system",
    "styled-component",
    "emotion",
    "ui-component",
    "ui",
    "style-props",
    "design-system"
  ],
  "sideEffects": false,
  "author": "Me <me@hello.com>",
  "homepage": "https://github.com/charizardxx/charizardxx#readme",
  "license": "MIT",
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charizardxx/charizardxx.git",
    "directory": "packages/components/core"
  },
  "bugs": {
    "url": "https://github.com/charizardxx/charizardxx/issues"
  },
  "dependencies": {    
  },
  "peerDependencies": {
    "@charizardxx/badge": ">=0.0.1-alpha.3",
    "@charizardxx/button": ">=0.0.1-alpha.3",
    "react": ">=18"
  },
  "devDependencies": {
    "@charizardxx/badge": "workspace:*",
    "@charizardxx/button": "workspace:*",
    "react": "^18.2.0",
    "clean-package": "2.2.0"
  },
  "scripts": {
    "build": "tsup src --dts",
    "dev": "pnpm build:fast -- --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "build:fast": "tsup src",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "clean-package": "../../clean-package.config.json"
}
